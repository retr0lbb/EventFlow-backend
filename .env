# ==========================================
# Variaveis do Banco de Dados PostgreSQL
# ==========================================
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_passwd
POSTGRES_DB=api_database
POSTGRES_PORT=5432

# ==========================================
# Variaveis do pgAdmin
# ==========================================
PGADMIN_DEFAULT_EMAIL=admin@pgadmin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# ==========================================
# Variaveis da API Spring Boot
# ==========================================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/api_database
SPRING_DATASOURCE_USERNAME=postgres_user
SPRING_DATASOURCE_PASSWORD=postgres_passwd
SERVER_PORT=8080